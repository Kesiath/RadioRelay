# RadioRelay server configuration.
# Copy this file to ".env" next to the server executable (or run the server
# from a directory containing it) and adjust the values below.
#
# Command-line arguments still take precedence over these values.

# Port the relay listens on (1-65535). Defaults to 2302 when unset.
PORT=2302

# Optional password required from connecting clients. Leave blank for none.
PASSWORD=
